# .markdownvdb/.config — Configuration for mdvdb
# This file lives inside the .markdownvdb/ directory alongside the index data.
# Priority: shell environment > .markdownvdb/.config > .env file > built-in defaults
#
# Shared secrets like OPENAI_API_KEY can live in a .env file (gitignored)
# and will be picked up automatically — no need to duplicate them here.

# ── Embedding ────────────────────────────────────────────────────────────────

# Embedding provider: openai, ollama, or custom
# MDVDB_EMBEDDING_PROVIDER=openai

# Model name passed to the embedding provider
# MDVDB_EMBEDDING_MODEL=text-embedding-3-small

# Dimensionality of embedding vectors (must be > 0)
# MDVDB_EMBEDDING_DIMENSIONS=1536

# Number of chunks sent per embedding API call
# MDVDB_EMBEDDING_BATCH_SIZE=100

# OpenAI API key (required when provider is openai)
# Tip: put this in .env instead so it's gitignored and shared with other tools
# OPENAI_API_KEY=

# Ollama server address (used when provider is ollama)
# OLLAMA_HOST=http://localhost:11434

# Custom embedding endpoint URL (used when provider is custom)
# MDVDB_EMBEDDING_ENDPOINT=

# ── Source ──────────────────────────────────────────────────────────────────

# Comma-separated list of directories to scan for markdown files
# MDVDB_SOURCE_DIRS=.

# Comma-separated glob patterns to ignore
# MDVDB_IGNORE_PATTERNS=

# Enable file watching for automatic re-indexing
# MDVDB_WATCH=true

# Debounce delay in milliseconds for file watch events
# MDVDB_WATCH_DEBOUNCE_MS=300

# ── Chunking ─────────────────────────────────────────────────────────────────

# Maximum tokens per chunk (must be > overlap)
# MDVDB_CHUNK_MAX_TOKENS=512

# Overlap tokens between consecutive chunks
# MDVDB_CHUNK_OVERLAP_TOKENS=50

# ── Clustering ───────────────────────────────────────────────────────────────

# Enable clustering of embeddings for faster search
# MDVDB_CLUSTERING_ENABLED=true

# Number of new vectors before triggering a rebalance
# MDVDB_CLUSTERING_REBALANCE_THRESHOLD=50

# ── Search ───────────────────────────────────────────────────────────────────

# Default number of results returned by search
# MDVDB_SEARCH_DEFAULT_LIMIT=10

# Minimum cosine similarity score to include in results (0.0–1.0)
# MDVDB_SEARCH_MIN_SCORE=0.0

# Search mode: hybrid (semantic+lexical), semantic, or lexical
# MDVDB_SEARCH_MODE=hybrid

# Reciprocal Rank Fusion smoothing constant (higher = gentler blending)
# MDVDB_SEARCH_RRF_K=60.0

# BM25 saturation normalization constant (a BM25 score equal to this maps to 0.5)
# MDVDB_BM25_NORM_K=1.5

# Boost results that are linked to/from top search matches
# MDVDB_SEARCH_BOOST_LINKS=false

# Number of link hops for graph-aware score boosting (1–3)
# Higher values boost files further away in the link graph (with diminishing effect)
# MDVDB_SEARCH_BOOST_HOPS=1

# Graph context expansion depth (0–3, 0 = disabled)
# When > 0, search results include extra chunks from linked files as supplementary context
# MDVDB_SEARCH_EXPAND_GRAPH=0

# Maximum graph context items per hop level (1–10)
# MDVDB_SEARCH_EXPAND_LIMIT=3

# ── Time Decay ───────────────────────────────────────────────────────────────

# Enable time decay to favor recently modified files in search results
# MDVDB_SEARCH_DECAY=false

# Half-life in days: after this many days, a file's score is halved
# MDVDB_SEARCH_DECAY_HALF_LIFE=90.0

# Comma-separated path prefixes excluded from decay (evergreen/pinned content)
# Files matching these prefixes keep their full score even when decay is enabled.
# MDVDB_SEARCH_DECAY_EXCLUDE=docs/reference,wiki/glossary

# Comma-separated path prefixes where decay applies (whitelist mode)
# When set, only files matching these prefixes get decay applied. Empty = all files.
# Exclude takes precedence over include when both match a path.
# MDVDB_SEARCH_DECAY_INCLUDE=journal,daily

