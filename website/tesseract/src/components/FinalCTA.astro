---
import SynthwaveGrid from "./SynthwaveGrid.astro";
import DownloadButton from "./DownloadButton.astro";
---

<section class="relative py-32 md:py-40 overflow-hidden">
  <!-- Backdrop: synthwave grid at low opacity -->
  <div class="absolute inset-0 z-0 opacity-30">
    <SynthwaveGrid />
  </div>

  <!-- Atmospheric glow orbs -->
  <div
    class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full opacity-10 blur-[100px]"
    style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-1/4 right-1/3 w-[400px] h-[400px] rounded-full opacity-10 blur-[80px]"
    style="background: radial-gradient(circle, #a855f7 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-4xl mx-auto px-6 text-center">
    <h2 class="fade-up neon-text text-3xl md:text-4xl font-bold tracking-tight mb-10" style="--delay: 0s;">
      Ready to see your knowledge differently?
    </h2>

    <!-- Download buttons -->
    <div
      class="fade-up flex flex-col sm:flex-row flex-wrap justify-center gap-4 mb-8"
      style="--delay: 0.1s;"
    >
      <DownloadButton platform="macos" variant="primary" />
      <DownloadButton platform="windows" variant="secondary" />
      <DownloadButton platform="linux" variant="secondary" />
    </div>

    <!-- Badges -->
    <div class="fade-up flex flex-wrap justify-center gap-3" style="--delay: 0.2s;">
      <span class="text-xs border border-border rounded-full px-3 py-1 text-muted-foreground">Open Source</span>
      <span class="text-xs border border-border rounded-full px-3 py-1 text-muted-foreground">MIT License</span>
      <span class="text-xs border border-border rounded-full px-3 py-1 text-muted-foreground">macOS &middot; Windows &middot; Linux</span>
    </div>
  </div>
</section>
