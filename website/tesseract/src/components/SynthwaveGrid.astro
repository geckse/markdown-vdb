<div class="synthwave-grid" aria-hidden="true">
  <div class="grid-layer"></div>
  <div class="grid-layer grid-layer--secondary"></div>
  <div class="horizon-glow"></div>
  <div class="radial-glow"></div>
  <div class="scan-lines"></div>
</div>

<style>
  .synthwave-grid {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .grid-layer {
    position: absolute;
    bottom: 0;
    left: -50%;
    width: 200%;
    height: 80%;
    background-image:
      linear-gradient(to right, rgba(0, 255, 255, 0.15) 1px, transparent 1px),
      linear-gradient(to top, rgba(0, 255, 255, 0.15) 1px, transparent 1px);
    background-size: 60px 40px;
    transform: perspective(500px) rotateX(65deg);
    transform-origin: center bottom;
    animation: grid-scroll 8s linear infinite;
  }

  .grid-layer--secondary {
    opacity: 0.4;
    background-size: 120px 80px;
    animation: grid-scroll 12s linear infinite;
  }

  .horizon-glow {
    position: absolute;
    bottom: 45%;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--cyan, #00ffff);
    box-shadow:
      0 0 20px var(--cyan, #00ffff),
      0 0 60px var(--cyan, #00ffff),
      0 0 120px rgba(0, 255, 255, 0.4);
    z-index: 1;
  }

  .radial-glow {
    position: absolute;
    bottom: 30%;
    left: 50%;
    width: 120%;
    height: 40%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(0, 255, 255, 0.12) 0%, transparent 70%);
    z-index: 0;
  }

  .scan-lines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
    opacity: 0.06;
    z-index: 2;
  }

  @keyframes grid-scroll {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 0 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .grid-layer {
      animation: none;
    }
  }
</style>
