---
interface Props {
  platform: "macos" | "windows" | "linux";
  variant?: "primary" | "secondary";
  href?: string;
}

const {
  platform,
  variant = "primary",
  href = "https://github.com/nicholasoxford/markdown-vdb/releases/latest",
} = Astro.props;

const labels: Record<string, { name: string; subtitle: string }> = {
  macos: { name: "Download for macOS", subtitle: "DMG" },
  windows: { name: "Download for Windows", subtitle: "Installer" },
  linux: { name: "Download for Linux", subtitle: "AppImage" },
};

const { name, subtitle } = labels[platform];

const baseClasses =
  "rounded-lg px-6 py-3 inline-flex items-center gap-2 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background";

const variantClasses =
  variant === "primary"
    ? "bg-primary text-black font-semibold hover:brightness-110"
    : "bg-transparent border border-primary/60 text-primary hover:opacity-80";
---

<a href={href} class:list={[baseClasses, variantClasses]}>
  {platform === "macos" && (
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11" />
    </svg>
  )}
  {platform === "windows" && (
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3 12V6.75l6-1.32v6.48L3 12zm17-9v8.75l-10 .08V5.67L20 3zM3 13l6 .09v6.81l-6-1.15V13zm7 .18l10 .08V21l-10-1.76V13.18z" />
    </svg>
  )}
