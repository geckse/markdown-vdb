---
import AppFrame from "./AppFrame.astro";

const badges = ['Slash Commands', 'Tables', 'Mermaid', 'Frontmatter'];
---

<section class="section-container" style="padding-top: var(--section-padding); padding-bottom: var(--section-padding);">
  <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- AppFrame column -->
    <div class="fade-up md:order-1" style="--delay: 0.2s;">
      <AppFrame variant="editor" title="Editor" />
    </div>

    <!-- Text column -->
    <div class="md:order-2">
      <span class="fade-up mono-label mb-4 block" style="--delay: 0s;">
        Markdown Editor
      </span>
      <h2 class="fade-up text-3xl md:text-4xl font-bold tracking-tight mb-4" style="--delay: 0.05s;">
        Write in Markdown, see it come alive
      </h2>
      <p class="fade-up text-muted-foreground mb-6" style="--delay: 0.1s;">
        A live preview editor that renders your Markdown as you type. Rich editing without the bloat — slash commands, tables, diagrams, and frontmatter metadata all work out of the box.
      </p>

      <!-- Feature badges -->
      <div class="fade-up flex flex-wrap gap-2" style="--delay: 0.15s;">
        {badges.map((badge) => (
          <span class="text-xs border border-border text-muted-foreground rounded-full px-3 py-1">
            {badge}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
