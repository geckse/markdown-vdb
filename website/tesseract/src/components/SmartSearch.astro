---
import AppFrame from "./AppFrame.astro";
---

<section class="section-container" style="padding-top: var(--section-padding); padding-bottom: var(--section-padding);">
  <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Text column -->
    <div>
      <span class="fade-up mono-label mb-4 block" style="--delay: 0s;">
        Smart Search
      </span>
      <h2 class="fade-up text-3xl md:text-4xl font-bold tracking-tight mb-4" style="--delay: 0.05s;">
        Search that understands what you mean
      </h2>
      <p class="fade-up text-muted-foreground mb-8" style="--delay: 0.1s;">
        Find your notes by meaning, not just keywords. Search for an idea and surface relevant notes even when they use completely different words.
      </p>

      <!-- Search mode callouts -->
      <div class="fade-up grid grid-cols-1 sm:grid-cols-3 gap-4" style="--delay: 0.15s;">
        <div class="bg-card border border-border rounded-lg p-4">
          <h3 class="text-sm font-semibold mb-1">Meaning-based</h3>
          <p class="text-xs text-muted-foreground">Finds related ideas even with different words.</p>
        </div>
        <div class="bg-card border border-border rounded-lg p-4">
          <h3 class="text-sm font-semibold mb-1">Keyword</h3>
          <p class="text-xs text-muted-foreground">Traditional text matching when you know exactly what to find.</p>
        </div>
        <div class="bg-card border border-border rounded-lg p-4">
          <h3 class="text-sm font-semibold mb-1">Combined</h3>
          <p class="text-xs text-muted-foreground">Best of both — meaning and keywords together.</p>
        </div>
      </div>
    </div>

    <!-- AppFrame column -->
    <div class="fade-up" style="--delay: 0.2s;">
      <AppFrame variant="search" title="Search" />
    </div>
  </div>
</section>
