---
---

<section class="section-container" style="padding-top: var(--section-padding); padding-bottom: var(--section-padding);">
  <div class="text-center max-w-3xl mx-auto">
    <span class="fade-up mono-label mb-4 block" style="--delay: 0s;">
      Your Data
    </span>
    <h2 class="fade-up text-3xl md:text-4xl font-bold tracking-tight mb-4" style="--delay: 0.05s;">
      Your files. Your machine. No cloud required.
    </h2>
    <p class="fade-up text-muted-foreground mb-12" style="--delay: 0.1s;">
      Your notes stay exactly where you put them. No accounts, no syncing, no trusting someone else with your thoughts.
    </p>
  </div>

  <!-- Trust cards -->
  <div class="fade-up grid md:grid-cols-3 gap-6 max-w-3xl mx-auto" style="--delay: 0.15s;">
    <div class="bg-card border border-border rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Plain Markdown</h3>
      <p class="text-xs text-muted-foreground">Standard .md files. No vendor lock-in. Take your notes anywhere.</p>
    </div>
    <div class="bg-card border border-border rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Local-First</h3>
      <p class="text-xs text-muted-foreground">Everything stays on your machine. No cloud sync. No account required.</p>
    </div>
    <div class="bg-card border border-border rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Open Source</h3>
      <p class="text-xs text-muted-foreground">MIT licensed. Audit the code. Contribute on GitHub.</p>
    </div>
  </div>
</section>
