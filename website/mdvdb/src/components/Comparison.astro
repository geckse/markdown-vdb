---
import SectionHeading from './SectionHeading.astro';
---

<section class="comparison">
  <SectionHeading id="comparison" subtitle="See how mdvdb stacks up against traditional vector stores">
    Comparison
  </SectionHeading>

  <!-- Sub-section A: Feature comparison table -->
  <div class="table-wrap">
    <table class="feature-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th class="highlight">mdvdb</th>
          <th>MySQL + vec</th>
          <th>SQLite-vec</th>
          <th>Pinecone</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Infrastructure</td>
          <td class="highlight"><span class="check">&check;</span> None</td>
          <td><span class="x">&times;</span> Server</td>
          <td><span class="check">&check;</span> None</td>
          <td><span class="x">&times;</span> Cloud</td>
        </tr>
        <tr>
          <td>Markdown-native</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
        </tr>
        <tr>
          <td>Link graph</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
        </tr>
        <tr>
          <td>Hybrid search</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="check">&check;</span></td>
        </tr>
        <tr>
          <td>Offline</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="check">&check;</span></td>
          <td><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
        </tr>
        <tr>
          <td>File watching</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
        </tr>
        <tr>
          <td>Agent-ready</td>
          <td class="highlight"><span class="check">&check;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="x">&times;</span></td>
          <td><span class="check">&check;</span></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Sub-section B: Benchmark bar chart -->
  <h3 class="chart-title">Benchmarks</h3>
  <div class="chart-grid">
    <!-- Index Speed -->
    <div class="chart-category">
      <h4>Index Speed</h4>
      <div class="bars">
        <div class="bar-row">
          <span class="bar-label">mdvdb</span>
          <div class="bar bar-mdvdb" style="--bar-pct: 90%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">SQLite-vec</span>
          <div class="bar bar-sqlite" style="--bar-pct: 60%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">MySQL+vec</span>
          <div class="bar bar-mysql" style="--bar-pct: 40%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
      </div>
    </div>

    <!-- Index Size -->
    <div class="chart-category">
      <h4>Index Size</h4>
      <div class="bars">
        <div class="bar-row">
          <span class="bar-label">mdvdb</span>
          <div class="bar bar-mdvdb" style="--bar-pct: 85%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">SQLite-vec</span>
          <div class="bar bar-sqlite" style="--bar-pct: 55%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">MySQL+vec</span>
          <div class="bar bar-mysql" style="--bar-pct: 35%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
      </div>
    </div>

    <!-- RAG Engine Speed -->
    <div class="chart-category">
      <h4>RAG Engine Speed</h4>
      <div class="bars">
        <div class="bar-row">
          <span class="bar-label">mdvdb</span>
          <div class="bar bar-mdvdb" style="--bar-pct: 95%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">SQLite-vec</span>
          <div class="bar bar-sqlite" style="--bar-pct: 50%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">MySQL+vec</span>
          <div class="bar bar-mysql" style="--bar-pct: 30%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
      </div>
    </div>

    <!-- Accuracy -->
    <div class="chart-category">
      <h4>Accuracy</h4>
      <div class="bars">
        <div class="bar-row">
          <span class="bar-label">mdvdb</span>
          <div class="bar bar-mdvdb" style="--bar-pct: 92%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">SQLite-vec</span>
          <div class="bar bar-sqlite" style="--bar-pct: 70%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
        <div class="bar-row">
          <span class="bar-label">MySQL+vec</span>
          <div class="bar bar-mysql" style="--bar-pct: 65%;"><!-- PLACEHOLDER: real benchmark --></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Legend -->
  <div class="legend">
    <div class="legend-item"><span class="legend-swatch swatch-mdvdb"></span> mdvdb</div>
    <div class="legend-item"><span class="legend-swatch swatch-sqlite"></span> SQLite-vec</div>
    <div class="legend-item"><span class="legend-swatch swatch-mysql"></span> MySQL+vec</div>
  </div>
</section>

<style>
  .comparison {
    padding: var(--section-padding, 6rem) 1.5rem;
    max-width: 1100px;
    margin-inline: auto;
  }

  /* --- Feature Table --- */
  .table-wrap {
    overflow-x: auto;
    margin-bottom: 3rem;
    -webkit-overflow-scrolling: touch;
  }

  .feature-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.875rem;
  }

  .feature-table th,
  .feature-table td {
    padding: 0.75rem 1rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border, #27272a);
  }

  .feature-table th {
    font-weight: 600;
    color: var(--color-text, #e4e4e7);
    background: var(--color-surface, #161617);
  }

  .feature-table td {
    color: var(--color-text-dim, #71717a);
    background: var(--color-surface, #161617);
  }

  .feature-table td:first-child,
  .feature-table th:first-child {
    text-align: left;
    font-weight: 500;
    color: var(--color-text, #e4e4e7);
  }

  .feature-table .highlight {
    background: rgba(0, 229, 255, 0.05);
  }

  .check {
    color: var(--color-success, #34d399);
    font-weight: 700;
  }

  .x {
    color: var(--color-error, #ef4444);
    font-weight: 700;
  }

  /* --- Bar Chart --- */
  .chart-title {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text, #e4e4e7);
    text-align: center;
    margin: 0 0 2rem;
  }

  .chart-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .chart-category h4 {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text, #e4e4e7);
    margin: 0 0 1rem;
    text-align: center;
  }

  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bar-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.65rem;
    color: var(--color-text-dim, #71717a);
    width: 5.5rem;
    flex-shrink: 0;
    text-align: right;
  }

  .bar {
    height: 1.25rem;
    border-radius: var(--radius-sm, 4px);
    width: var(--bar-pct);
    transition: width 0.4s ease;
  }

  .bar-mdvdb {
    background: var(--color-primary, #00E5FF);
  }

  .bar-sqlite {
    background: var(--color-info, #60a5fa);
  }

  .bar-mysql {
    background: var(--color-text-dim, #71717a);
  }

  /* --- Legend --- */
  .legend {
    display: flex;
    justify-content: center;
    gap: 2rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--color-text-dim, #71717a);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .legend-swatch {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 2px;
  }

  .swatch-mdvdb { background: var(--color-primary, #00E5FF); }
  .swatch-sqlite { background: var(--color-info, #60a5fa); }
  .swatch-mysql { background: var(--color-text-dim, #71717a); }

  /* --- Mobile --- */
  @media (max-width: 768px) {
    .comparison {
      padding: var(--section-padding-mobile, 3rem) 1rem;
    }

    .chart-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
