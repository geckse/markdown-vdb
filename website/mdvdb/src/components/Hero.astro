---
import SynthwaveGrid from './SynthwaveGrid.astro';
import Terminal from './Terminal.astro';
import Badge from './Badge.astro';
import Button from './Button.astro';

const terminalLines = [
  { type: 'command' as const, text: 'mdvdb search "vector database" --limit 3' },
  { type: 'output' as const, text: '' },
  { type: 'output' as const, text: '  0.94  docs/architecture.md#storage-layer', color: '#51CF66' },
  { type: 'output' as const, text: '         "Uses HNSW index for sub-ms nearest neighbor search"' },
  { type: 'output' as const, text: '' },
  { type: 'output' as const, text: '  0.87  README.md#getting-started', color: '#00E5FF' },
  { type: 'output' as const, text: '         "A filesystem-native vector database built around Markdown"' },
  { type: 'output' as const, text: '' },
  { type: 'output' as const, text: '  0.81  guides/semantic-search.md#overview', color: '#FFBD2E' },
  { type: 'output' as const, text: '         "Hybrid BM25 + vector search with RRF fusion"' },
  { type: 'output' as const, text: '' },
  { type: 'comment' as const, text: '3 results in 2ms — zero infrastructure required' },
];
---

<section class="hero" id="hero">
  <SynthwaveGrid />
  <div class="hero-content">
    <div class="hero-text">
      <Badge variant="success">OPEN SOURCE</Badge>
      <h1 class="hero-headline neon-text">
        The Vector Database That Lives in Your Filesystem
      </h1>
      <p class="hero-subtitle">
        Rust-powered semantic search for your Markdown files. Zero infrastructure, zero config, instant results.
      </p>
      <div class="hero-cta">
        <Button href="#how-to-use" variant="primary">GET STARTED</Button>
        <Button href="https://github.com/nicholasrq/markdown-vdb" variant="secondary" target="_blank" rel="noopener noreferrer">VIEW ON GITHUB</Button>
      </div>
      <div class="hero-install">
        <code>cargo install mdvdb</code>
      </div>
    </div>
    <div class="hero-visuals">
      <Terminal title="mdvdb" lines={terminalLines} />
      <div class="tesseract-placeholder" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    width: 100%;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .hero-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
    margin: 0;
  }

  .neon-text {
    text-shadow:
      0 0 10px rgba(0, 229, 255, 0.3),
      0 0 40px rgba(0, 229, 255, 0.1);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted, #8888aa);
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-install {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.875rem;
    color: var(--color-text-muted, #8888aa);
    background: rgba(0, 229, 255, 0.05);
    border: 1px solid rgba(0, 229, 255, 0.15);
    border-radius: 6px;
    padding: 0.5em 1em;
  }

  .hero-install code {
    color: var(--color-primary, #00E5FF);
  }

  .hero-visuals {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tesseract-placeholder {
    width: 100%;
    height: 120px;
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-headline {
      font-size: 2.25rem;
    }

    .hero-visuals {
      display: none;
    }
  }
</style>
