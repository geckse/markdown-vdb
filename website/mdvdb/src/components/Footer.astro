---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <span class="footer-brand">mdvdb</span>
    <nav class="footer-links" aria-label="Footer">
      <a href="https://github.com/nicholasgriffintn/markdown-vdb" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://github.com/nicholasgriffintn/markdown-vdb#readme" target="_blank" rel="noopener noreferrer">Docs</a>
      <a href="#how-to-use">Install</a>
      <a href="https://github.com/nicholasgriffintn/tesseract" target="_blank" rel="noopener noreferrer">Tesseract</a>
    </nav>
    <p class="footer-copyright">&copy; {currentYear} Markdown VDB contributors. MIT License.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-xl) var(--spacing-md);
    text-align: center;
  }

  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .footer-brand {
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--font-size-lg);
    font-family: var(--font-mono);
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: text-decoration 0.15s ease;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .footer-copyright {
    color: var(--color-text-dim);
    font-size: var(--font-size-xs);
    margin: 0;
  }
</style>
